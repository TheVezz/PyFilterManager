# Percorso del database SQLite (usato se FILTRI_DATABASE_URL non è impostato)
FILTRI_DATABASE_PATH=data/filtri.db

# URL completo del database (PostgreSQL, MySQL, ecc.)
# Ha priorità su FILTRI_DATABASE_PATH
# FILTRI_DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/filtri
# FILTRI_DATABASE_URL=mysql+pymysql://user:password@localhost:3306/filtri
